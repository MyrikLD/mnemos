# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file (mounted as a Docker volume).
MNEMOS_DB_PATH=/data/memory.db

# ── ONNX model ────────────────────────────────────────────────────────────────
# Directory containing model.onnx and tokenizer.json.
MNEMOS_MODEL_DIR=/app/src/mnemos/onnx

# ── Server ────────────────────────────────────────────────────────────────────
MNEMOS_HOST=0.0.0.0
MNEMOS_PORT=8000

# ── Search tuning ─────────────────────────────────────────────────────────────
# MNEMOS_RRF_K=60
# MNEMOS_DEFAULT_LIMIT=10
# MNEMOS_SIM_THRESHOLD=0.7

# ── OAuth 2.1 (optional) ──────────────────────────────────────────────────────
# All three must be set to enable authentication.
# MNEMOS_BASE_URL=https://memory.example.com
# MNEMOS_OAUTH_JWT_SECRET=change-me-to-a-long-random-secret
# MNEMOS_PASSWORD=change-me-to-a-strong-password
